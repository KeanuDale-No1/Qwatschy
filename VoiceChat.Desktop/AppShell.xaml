<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VoiceChat.Desktop.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VoiceChat.Desktop"
    Title="VoiceChat.Desktop">


    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Channels"
        Icon="dotnet_bot.png"
        ContentTemplate="{DataTemplate local:ChannelPage}"
        Route="ChannelPage" />

    <ShellContent
        Title="Einstellungen"
        Icon="dotnet_bot.png"
        ContentTemplate="{DataTemplate local:SettingsPage}"
        Route="SettingsPage" />

</Shell>
