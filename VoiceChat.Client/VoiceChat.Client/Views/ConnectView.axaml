<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VoiceChat.Client.ViewModels"
             x:DataType="vm:ConnectViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VoiceChat.Client.Views.ConnectView">
  <Design.DataContext>
        <vm:ConnectViewModel />
  </Design.DataContext> 

  <StackPanel HorizontalAlignment="Center" 
              VerticalAlignment="Center" Spacing="10" >
        <TextBlock Text="Username" FontSize="16"/>
        <TextBox Width="200" Text="{Binding Username}"/>
        <TextBlock Text="Enter Server IP:" FontSize="16"/>
        <TextBox Width="200" Text="{Binding  ServerAddress}"/>
    <Button Content="Verbinden" Command="{Binding ConnectCommand}"/>
 </StackPanel>
</UserControl>
