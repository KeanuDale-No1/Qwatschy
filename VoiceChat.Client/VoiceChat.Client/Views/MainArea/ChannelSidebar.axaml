<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:models="using:VoiceChat.Shared.Models"
			 mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="450"
			 xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea"
			 x:Class="VoiceChat.Client.Views.MainArea.ChannelSidebarView"
			 x:DataType="vm:ChannelSidebarViewModel">
	 
	
	
	<Grid RowDefinitions="40,*,1,*">
		<Panel Grid.Row="0" Classes="ChannelPanel" Background="Beige" Margin="5" >
			<TextBlock Text="Channels:"
					   FontSize="16"
					   FontWeight="Bold"
					   Margin="4 0 0 0"
					   VerticalAlignment="Center"
					   HorizontalAlignment="Left" />
			<Button Content="+"
					Command="{Binding CreateChannelCommand}"
					CornerRadius="10"
					Padding="4 4 4 4"
					
					BorderThickness="0"
					Margin="0 0 4 0"
					HorizontalAlignment="Right"
					Foreground="White"/>
		</Panel>
		<ScrollViewer Grid.Row="1" Margin="0 0 0 0">
			<ItemsControl ItemsSource="{Binding Channels}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Panel Margin="10 0 10 0">
							<TextBlock Text="{Binding Name}"
									   FontSize="14"
									   Margin="0 4"
									   VerticalAlignment="Center"
									   HorizontalAlignment="Left" />
							<Button Content="🔉"
									Command="{Binding $parent[ItemsControl].DataContext.JoinChannelCommand}"
									CornerRadius="6"
									Padding="8"
									Margin="0 4"
									Background="#2B2D31"
									BorderThickness="0"
									VerticalAlignment="Center"
									HorizontalAlignment="Right"
									Foreground="White" />
						</Panel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl >
		</ScrollViewer>

		<GridSplitter Grid.Row="2"  Height="1" ResizeDirection="Rows"/>

		<StackPanel Grid.Row="3" Margin="20">
			<TextBlock Margin="0 5">Benutzer online:</TextBlock>
			<ItemsControl ItemsSource="{Binding OnlineUsers}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Vertical">
							<TextBlock Text="{Binding DisplayName}" />
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl >
		</StackPanel>
	</Grid>


</UserControl>
