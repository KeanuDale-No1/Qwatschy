<UserControl Padding="0" xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="450"
			 xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea"
			 xmlns:cv="using:VoiceChat.Client.Converters"
			 x:Class="VoiceChat.Client.Views.MainArea.ChannelSidebarView"
			 x:DataType="vm:ChannelSidebarViewModel"
			 Background="{DynamicResource SurfaceBrush}">

	<Design.DataContext>
		<vm:ChannelSidebarViewModel />
	</Design.DataContext>

	<UserControl.Resources>
		<cv:EqualityMultiConverter x:Key="EqualityMultiConverter" />
		<cv:IsSelectedConverter x:Key="IsSelectedConverter" />
	</UserControl.Resources>

	<Grid RowDefinitions="Auto,*">
		<StackPanel Grid.Row="0">
			<Border Classes="ChatHeader">
				<TextBlock Classes="header" Text="Channels"/>
			</Border>

			<DockPanel Margin="8,8,8,8" LastChildFill="True">
				<Button DockPanel.Dock="Right"
						Margin="0,0,0,0"
						Content="➕"
						FontSize="12"
						VerticalContentAlignment="Center"
						HorizontalContentAlignment="Center"
						Classes="icon"
						Command="{Binding CreateChannelCommand}"/>
				<TextBox x:Name="NewChannelTextBox"
						 DockPanel.Dock="Left"
						 Watermark="new channel"
						 MinWidth="80"
						 Text="{Binding NewChannelName}"/>
			</DockPanel>

			<ScrollViewer>
				<ItemsControl ItemsSource="{Binding Channels}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<VirtualizingStackPanel/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Classes="channelItem"
									PointerPressed="OnChannelClick"
									Margin="0,2">
								<Border.Background>
									<MultiBinding Converter="{StaticResource IsSelectedConverter}">
										<Binding Path="Id"/>
										<Binding Path="$parent[ItemsControl].DataContext.SelectedChannel"/>
									</MultiBinding>
								</Border.Background>
								<Grid Classes="channelRow" ColumnDefinitions="*,Auto">
									<TextBlock Grid.Column="0"
											   Text="{Binding Name}"
											   Margin="8,0"
											   VerticalAlignment="Center"/>
									<Button Grid.Column="1"
											Classes="channelJoinButton"
											Command="{Binding $parent[ItemsControl].DataContext.JoinChannelCommand}"
											CommandParameter="{Binding .}"
											VerticalContentAlignment="Center"
											HorizontalContentAlignment="Center"
											Padding="0"
											FontSize="16"
											Content="🔉"/>
								</Grid>
								<Border.ContextMenu>
									<ContextMenu>
										<MenuItem Header="Löschen"
												  Command="{Binding $parent[UserControl].DataContext.DeleteChannelCommand }"
												  CommandParameter="{Binding .}"/>
										<MenuItem Header="-"/>
										<MenuItem Header="Close"/>
									</ContextMenu>
								</Border.ContextMenu>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
		</StackPanel>

		<StackPanel Grid.Row="1">
			<Separator/>
			<Border Classes="ChatHeader">
				<TextBlock Classes="header" Text="Online"/>
			</Border>
			<ItemsControl ItemsSource="{Binding SelectedChannelUsers}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Classes="memberItem">
							<Ellipse Classes="statusIndicator statusOnline"/>
							<TextBlock Text="{Binding DisplayName}"/>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</StackPanel>
	</Grid>
</UserControl>
