<UserControl Padding="0"
    xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea"

             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VoiceChat.Client.Views.MainArea.ServerInformationView"
             x:DataType="vm:ServerInformationViewModel">

    <Border Classes="serverPanel">
        <StackPanel Classes="serverInfo">
            <Border Classes="serverHeader">
                <Image Classes="serverIcon"/>
            </Border>

            <TextBlock Classes="serverInfoTitle"
                       Text="{Binding ServerName}"/>

            <Separator/>

            <TextBlock Classes="serverInfoCaption"
                       Text="Willkommen beim Voice Chat Server!"/>
        </StackPanel>
    </Border>
</UserControl>