<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:DataType="vm:MainAreaViewModel"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:VoiceChat.Client.ViewModels.MainArea"
			 xmlns:vmc="clr-namespace:VoiceChat.Client.ViewModels.MainArea.Componets"
			 xmlns:me="clr-namespace:VoiceChat.Client.Extensions"
			 xmlns:views="clr-namespace:VoiceChat.Client.Views.MainArea"
			 x:Class="VoiceChat.Client.Views.MainArea.MainAreaView"
			 Background="{DynamicResource BackgroundBrush}">



	<Panel>
		<Grid ColumnDefinitions="*, 64" 
			  HorizontalAlignment="Stretch" 
			  VerticalAlignment="Stretch" 
			  IsVisible="{Binding !IsBusy}">
			<!-- Column 0: Header + 3 Spalten -->
			<Grid Grid.Column="0" RowDefinitions="48, *">
				<!-- Row 0: Header -->
				<ContentControl Grid.Row="0" Content="{me:Resolve vmc:ActionbarViewModel}" />

				<!-- Row 1: 3 Spalten -->
				<Grid Grid.Row="1" ColumnDefinitions="220, 1, *, 1, 220">
					<ContentControl Grid.Column="0" Content="{me:Resolve vm:ChannelSidebarViewModel}" />
					<GridSplitter Grid.Column="1" Classes="splitter" ResizeDirection="Columns"/>
					<ContentControl Grid.Column="2" Content="{me:Resolve vm:ChatViewModel}" />
					<GridSplitter Grid.Column="3" Classes="splitter" ResizeDirection="Columns"/>
					<ContentControl Grid.Column="4" Content="{me:Resolve vmc:ServerInformationViewModel}" />
				</Grid>
			</Grid>

			<!-- Column 1: Durchgehende rechte Spalte -->
			<ContentControl Grid.Column="1" HorizontalAlignment="Right" Content="{me:Resolve vmc:ServerConnectionsViewModel}" />

			<Panel Background="{DynamicResource BackgroundBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsVisible="{Binding IsBusy}">
				<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
					<ProgressBar IsIndeterminate="True" Width="200" />
					<TextBlock Text="Lade deine Verbindungen..." HorizontalAlignment="Center" />
				</StackPanel>
			</Panel>
		</Grid>
	</Panel>

</UserControl>