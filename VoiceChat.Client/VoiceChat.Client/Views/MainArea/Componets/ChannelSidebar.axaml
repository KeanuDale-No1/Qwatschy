<UserControl Padding="0" xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea.Componets"
			 xmlns:cv="using:VoiceChat.Client.Converters"
			 mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="450"
			 x:Class="VoiceChat.Client.Views.MainArea.Componets.ChannelSidebarView"
			 x:DataType="vm:ChannelSidebarViewModel"
			 Background="{DynamicResource SurfaceBrush}">

	<Design.DataContext>
		<vm:ChannelSidebarViewModel />
	</Design.DataContext>

	<UserControl.Resources>
		<cv:EqualityMultiConverter x:Key="EqualityMultiConverter" />
		<cv:IsSelectedConverter x:Key="IsSelectedConverter" />
	</UserControl.Resources>

	<Grid RowDefinitions="Auto,*">
		<StackPanel Grid.Row="0">
			<Border Classes="ChatHeader">
				<TextBlock Classes="header" Text="Channels"/>
			</Border>
			
			<ScrollViewer>
				<ItemsControl ItemsSource="{Binding serverViewService.ServerConnectionInfo.ChannelInfos}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<VirtualizingStackPanel/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Classes="channelItem"
									Margin="0,2">
								<Border.Background>
									<MultiBinding Converter="{StaticResource IsSelectedConverter}">
										<Binding Path="Id"/>
										<Binding Path="$parent[ItemsControl].DataContext.SelectedChannel"/>
									</MultiBinding>
								</Border.Background>
								<Grid Classes="channelRow" ColumnDefinitions="*,Auto,Auto">
									<TextBlock Grid.Column="0"
											   Text="{Binding Name}"
											   Margin="8,0"
											   VerticalAlignment="Center"/>
									<TextBlock Grid.Column="1"
											   Text="{Binding UnreadCount}"
											   IsVisible="{Binding UnreadCount}"
											   Margin="4,0"
											   VerticalAlignment="Center"
											   FontWeight="Bold"
											   Foreground="{DynamicResource PrimaryBrush}"/>
								<Button Grid.Column="2"
										Classes="channelJoinButton"
										Command="{Binding $parent[ItemsControl].DataContext.JoinChannelCommand}"
										CommandParameter="{Binding .}"
										VerticalContentAlignment="Center"
										HorizontalContentAlignment="Center"
										Padding="0"
										FontSize="16"
										Content="V"
										ToolTip.Tip="Voice Channel"/>
								</Grid>
								<Border.ContextMenu>
									<ContextMenu>
										<MenuItem Header="Löschen"
												  Command="{Binding $parent[UserControl].DataContext.DeleteChannelCommand }"
												  CommandParameter="{Binding .}"/>
										<MenuItem Header="-"/>
										<MenuItem Header="Close"/>
									</ContextMenu>
								</Border.ContextMenu>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
		</StackPanel>

		<StackPanel Grid.Row="1">
			<Separator/>
			<Border Classes="ChatHeader">
				<TextBlock Classes="header" Text="Online"/>
			</Border>
			<!-->
			<ItemsControl ItemsSource="{Binding SelectedChannelUsers}"
						  x:Name="UsersItemsControl">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Classes="userItem"
								Padding="8,4"
								PointerPressed="OnUserClick">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<Ellipse Classes="statusIndicator statusOnline" Width="8" Height="8"/>
								<TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl> -->
		</StackPanel>
	</Grid>
</UserControl>
