<UserControl Padding="0" xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea.Componets"
			 xmlns:cv="using:VoiceChat.Client.Converters"
			 mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="450"
			 x:Class="VoiceChat.Client.Views.MainArea.Componets.ChannelSidebarView"
			 x:DataType="vm:ChannelSidebarViewModel"
			 Background="{DynamicResource SurfaceBrush}">

	<Design.DataContext>
		<vm:ChannelSidebarViewModel />
	</Design.DataContext>

	<UserControl.Resources>
		<cv:EqualityMultiConverter x:Key="EqualityMultiConverter" />
		<cv:IsSelectedConverter x:Key="IsSelectedConverter" />
	</UserControl.Resources>

	<StackPanel>
		<Border Classes="ChatHeader">
			<Panel>
				<TextBlock Classes="header" Text="Channels"/>
				<Button Classes="addChannelButton"
						Command="{Binding AddChannelCommand}"
						HorizontalAlignment="Right"
						VerticalContentAlignment="Center"
						HorizontalContentAlignment="Center"
						Padding="0"
						ToolTip.Tip="Add Channel">
					<PathIcon Data="M440-280h80v-160h160v-80H520v-160h-80v160H280v80h160v160Zm40 200q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z" Width="16" Height="16" HorizontalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
				</Button>
			</Panel>
		</Border>
		<ScrollViewer>
			<ItemsControl ItemsSource="{Binding ServerViewService.ServerConnectionInfo.ChannelInfos}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<VirtualizingStackPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Classes="channelItem"
								Margin="0,2">
							<!--<Border.Background>
							<MultiBinding Converter="{StaticResource IsSelectedConverter}">
							<Binding Path="Id"/>
							<Binding Path="$parent[ItemsControl].DataContext.SelectedChannel"/>
							</MultiBinding>
							</Border.Background>-->
							<StackPanel>
								<Grid Classes="channelRow" ColumnDefinitions="*,Auto,Auto">
									<TextBlock Grid.Column="0"
											   Text="{Binding Name}"
											   Margin="8,0"
											   VerticalAlignment="Center"/>
									<TextBlock Grid.Column="1"
											   Text="{Binding UnreadMessagesCount}"
											   IsVisible="{Binding UnreadMessagesCount}"
											   Margin="4,0"
											   VerticalAlignment="Center"
											   FontWeight="Bold"
											   Foreground="{DynamicResource PrimaryBrush}"/>
									<Button Grid.Column="2"
											Classes="channelJoinButton"
											Command="{Binding $parent[ItemsControl].DataContext.JoinChannelCommand}"
											CommandParameter="{Binding .}"
											VerticalContentAlignment="Center"
											HorizontalContentAlignment="Center"
											Padding="0"
											FontSize="16"
											Content="V"
											ToolTip.Tip="Voice Channel"/>
								</Grid>
								<ItemsControl ItemsSource="{Binding ConnectedUsers}"
											  Margin="24,0,0,0">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding Username}"
													   Margin="8,2"
													   FontSize="12"
													   Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
							<Border.ContextMenu>
								<ContextMenu>
									<MenuItem Header="Löschen"
											  Command="{Binding $parent[UserControl].DataContext.DeleteChannelCommand }"
											  CommandParameter="{Binding .}"/>
									<MenuItem Header="-"/>
									<MenuItem Header="Close"/>
								</ContextMenu>
							</Border.ContextMenu>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</StackPanel>
</UserControl>
