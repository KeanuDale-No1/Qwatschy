<UserControl Padding="0" xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea.Componets"
			 xmlns:cv="using:VoiceChat.Client.Converters"
			 mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="450"
			 x:Class="VoiceChat.Client.Views.MainArea.Componets.ChannelSidebarView"
			 x:DataType="vm:ChannelSidebarViewModel"
			 Background="{DynamicResource SurfaceBrush}">

	<Design.DataContext>
		<vm:ChannelSidebarViewModel />
	</Design.DataContext>

	<UserControl.Resources>
		<cv:EqualityMultiConverter x:Key="EqualityMultiConverter" />
		<cv:IsSelectedConverter x:Key="IsSelectedConverter" />
	</UserControl.Resources>

	<Grid RowDefinitions="Auto,*">
		<Border Grid.Row="0" Classes="ChatHeader">
			<Grid ColumnDefinitions="*,Auto">
				<TextBlock Grid.Column="0" Classes="header" Text="Channels" VerticalAlignment="Center"/>
				<Button Grid.Column="1" Classes="addChannelButton"
						Command="{Binding AddChannelCommand}"
						ToolTip.Tip="Add Channel">
					<PathIcon Data="M440-280h80v-160h160v-80H520v-160h-80v160H280v80h160v160Zm40 200q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"
							  Width="18"
							  Height="18"/>
				</Button>
			</Grid>
		</Border>
		<ScrollViewer Grid.Row="1">
			<ItemsControl ItemsSource="{Binding ServerViewService.OpenServerInfo.ChannelInfos}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<VirtualizingStackPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel>
							<Border Classes="channelItem">
								<Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
									<StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
										<TextBlock Classes="channelName" Text="{Binding Name}" Margin="8,0"/>
										<Border Classes="unreadBadge" IsVisible="{Binding UnreadMessagesCount}" Background="{DynamicResource PrimaryBrush}">
											<TextBlock Text="{Binding UnreadMessagesCount}" FontSize="11" Foreground="White"/>
										</Border>
									</StackPanel>
									<Button Grid.Column="1" Grid.Row="0" Classes="channelJoinButton"
											Command="{Binding $parent[ItemsControl].DataContext.JoinVoiceChatChannelCommand}"
											CommandParameter="{Binding .}"
											VerticalAlignment="Center"
											ToolTip.Tip="Voice Channel">
										<PathIcon Data="M619.5-811.5Q685-783 734-734t77.5 114.5Q840-554 840-480t-28.5 139.5Q783-275 734-226t-114.5 77.5Q554-120 480-120q-41 0-79-9t-76-26l61-61q23 8 46.5 12t47.5 4q116 0 198-82t82-198q0-116-82-198t-198-82q-116 0-198 82t-82 198q0 24 4 47.5t12 46.5l-60 60q-18-36-27-74.5t-9-79.5q0-74 28.5-139.5T226-734q49-49 114.5-77.5T480-840q74 0 139.5 28.5ZM520-320v-144L176-120l-56-56 344-344H320v-80h280v280h-80Z"
												  Width="16"
												  Height="16"/>
									</Button>
								</Grid>
								<Border.ContextMenu>
									<ContextMenu>
										<MenuItem Header="Löschen"
												  Command="{Binding $parent[UserControl].DataContext.DeleteChannelCommand }"
												  CommandParameter="{Binding .}"/>
										<MenuItem Header="-"/>
										<MenuItem Header="Close"/>
									</ContextMenu>
								</Border.ContextMenu>
							</Border>
							<ItemsControl Grid.Column="0" Grid.Row="1" ItemsSource="{Binding ConnectedUsers}" Margin="24,4,0,0">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<StackPanel>
											<TextBlock Classes="channelUser" Text="{Binding Username}"/>
											<StackPanel.ContextMenu>
												<ContextMenu>
													<MenuItem Header="User Info"/>
													<MenuItem Header="Message"/>
													<MenuItem Header="Kick from Channel"
															  Command="{Binding $parent[UserControl].DataContext.KickUserCommand}"
															  CommandParameter="{Binding .}"/>
												</ContextMenu>
											</StackPanel.ContextMenu>
										</StackPanel>

									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>
