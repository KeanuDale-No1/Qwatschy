<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="64" d:DesignHeight="450"
			 xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea.Componets"
			 x:DataType="vm:ServerConnectionsViewModel"
			 x:Class="VoiceChat.Client.Views.MainArea.Componets.ServerConnectionsView">

	<ScrollViewer>
		<StackPanel>
			<ItemsControl ItemsSource="{Binding Servers}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Horizontal">
							<Border MaxHeight="48" Height="48" Width="48" Padding="0" Margin="0">
								<Button Command="{Binding $parent[ItemsControl].DataContext.ConnectServerCommand}"
										CommandParameter="{Binding .}"
										Height="60"
										Width="60"
										Content="{Binding Abbr}"
										FontSize="32"
										FontWeight="ExtraBold"
										HorizontalAlignment="Center"
										VerticalAlignment="Center"
										HorizontalContentAlignment="Center"
										VerticalContentAlignment="Center"
										ToolTip.Tip="{Binding ServerName}"/>
							</Border>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
			<Border MaxHeight="64" Height="64" Padding="0" Margin="0">
				<Button Command="{Binding AddServerCommand}"
						Height="60"
						Width="60"
						Content="+"
						FontSize="32"
						FontWeight="ExtraBold"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						HorizontalContentAlignment="Center"
						VerticalContentAlignment="Center"/>
			</Border>
			<Separator Margin="0" Padding="0" Height="1" MaxHeight="1"/>
		</StackPanel>
	</ScrollViewer>


</UserControl>
