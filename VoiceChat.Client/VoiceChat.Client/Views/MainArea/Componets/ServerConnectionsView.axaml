<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="64" d:DesignHeight="450"
			 xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea.Componets"
			 x:DataType="vm:ServerConnectionsViewModel"
			 x:Class="VoiceChat.Client.Views.MainArea.Componets.ServerConnectionsView">

	<ScrollViewer Classes="serverSidebar">
		<StackPanel>
			<ItemsControl ItemsSource="{Binding Servers}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Button Classes="serverIcon"
								Command="{Binding $parent[ItemsControl].DataContext.OpenServerCommand}"
								IsEnabled="{Binding IsConnected}"
								CommandParameter="{Binding .}"
								ToolTip.Tip="{Binding ServerName}">
							<Grid RowDefinitions="*" ColumnDefinitions="*" >
								<TextBlock Grid.Row="0" Grid.Column="0"
										   Text="{Binding Abbr}"
										   HorizontalAlignment="Center"
										   VerticalAlignment="Center"/>
								<Button Classes="serverCloseIcon"
										Grid.Row="0" Grid.Column="0"
										Command="{Binding $parent[ItemsControl].DataContext.RemoveServerCommand}"
										CommandParameter="{Binding .}"
										HorizontalAlignment="Right"
										VerticalAlignment="Top"
										Content="✕"/>
							</Grid>
						</Button>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
			<Button Classes="addServer"
					Command="{Binding AddServerCommand}"
					Content="+"/>
			<Border Classes="serverDivider"/>
		</StackPanel>
	</ScrollViewer>

</UserControl>