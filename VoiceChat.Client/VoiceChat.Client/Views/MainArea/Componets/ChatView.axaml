<UserControl Padding="0" xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea.Componets"

             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VoiceChat.Client.Views.MainArea.Componets.ChatView"
             x:DataType="vm:ChatViewModel">

    <Design.DataContext>
        <vm:ChatViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <Image Grid.Row="0" Grid.RowSpan="3"
               Source="avares://VoiceChat.Client/Assets/qwatschy_logo.png"
               Stretch="Uniform"
               Opacity="0.1"
               MaxWidth="600"
               MaxHeight="600"
               IsHitTestVisible="False"/>

        <Border Grid.Row="0" Classes="ChatHeader">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="💬 "
                           IsVisible="{Binding IsInputEnabled}"/>
                <TextBlock Classes="header"
                           Text="{Binding ChannelTitle}"
                           IsVisible="{Binding IsInputEnabled}"/>
                <TextBlock Classes="header"
                           Text="Wähle einen Channel aus"
                           FontStyle="Italic"
                           IsVisible="{Binding !IsInputEnabled}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          x:Name="ChatScrollViewer"
                          IsVisible="{Binding !IsInputEnabled}">
                <Border Background="{DynamicResource SurfaceBrush}"
                        Padding="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Wähle einen Channel aus"
                                   Classes="header"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Du musst erst einen Channel auswählen,"
                                   Classes="caption"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="bevor du Nachrichten senden kannst."
                                   Classes="caption"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Grid IsVisible="{Binding IsInputEnabled}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              x:Name="ChatScrollViewerMessages"
                              ScrollChanged="OnScrollChanged">
                    
                    <Grid RowDefinitions="Auto,*">
                        <Button Grid.Row="0"
                                Content="Mehr laden..."
                                HorizontalAlignment="Center"
                                Margin="0,8,0,8"
                                Padding="12,6"
                                Command="{Binding LoadMoreMessagesCommand}"
                                IsVisible="{Binding HasMoreMessages}"
                                IsEnabled="{Binding !IsLoadingMore}"/>
                        
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding Messages}"
                                      x:Name="MessagesItemsControl"
                                      Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="messageBubble"
                                            HorizontalAlignment="{Binding HorizontalAlignment}"
                                            Margin="0,2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Username}"
                                                       Classes="caption"
                                                       IsVisible="{Binding !IsOwnMessage}"/>
                                            <TextBlock Classes="ChatMessage"
                                                       Text="{Binding Text}"
                                                       FontSize="14"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4" VerticalAlignment="Bottom"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>

                <Border Background="{DynamicResource SurfaceBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="16,8"
                        CornerRadius="8"
                        BoxShadow="0 2 8 0 #40000000"
                        IsVisible="{Binding IsLoading}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ProgressBar IsIndeterminate="True" Width="20" Height="20"/>
                        <TextBlock Text="Lädt Nachrichten..." 
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Classes="inputBox"
                Margin="8">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBox Text="{Binding MessageInput}"
                         Watermark="...Message..."
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="4"
                         IsEnabled="{Binding IsInputEnabled}">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter"
                                    Command="{Binding SendMessageCommand}" />
                    </TextBox.KeyBindings>
                </TextBox>
                <Button Grid.Column="1"
                        Classes="icon"
                        Command="{Binding SendMessageCommand}"
                        IsEnabled="{Binding IsInputEnabled}"
                        Content="⮞"/>
            </Grid>
        </Border>
    </Grid>

</UserControl>
