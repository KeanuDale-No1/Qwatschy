<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VoiceChat.Client.Views.MainArea.ChatView"
             x:DataType="vm:ChatViewModel">
  <Grid RowDefinitions="*,Auto">
       
         <ItemsControl ItemsSource="{Binding Messages}">
             <ItemsControl.ItemTemplate>
                 <DataTemplate>
                         <TextBlock Text="{Binding Text}" 
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0 0 0 8"
                       HorizontalAlignment="Left" />
                 </DataTemplate>
             </ItemsControl.ItemTemplate>
         </ItemsControl >


      <Border Grid.Row="1" CornerRadius="8"
              Padding="5"
            Background="#2B2B2B"
            BorderBrush="#444"
            BorderThickness="1">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBox Text="{Binding MessageInput}" BorderBrush="Transparent" Watermark="...Message..." />
                <Button Command="{Binding SendMessageCommand}" 
                        Grid.Column="1"
                        Content="⮞" 
                        Background="Transparent" 
                        BorderThickness="0"  
                        Margin="5,0,0,0"/>
            </Grid>
          </Border>
    </Grid>
</UserControl>
