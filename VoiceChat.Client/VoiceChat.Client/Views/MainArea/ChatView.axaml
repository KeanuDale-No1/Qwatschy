<UserControl Padding="10 0 10 0" xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:VoiceChat.Client.ViewModels.MainArea"

			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="VoiceChat.Client.Views.MainArea.ChatView"
			 x:DataType="vm:ChatViewModel">

	<Design.DataContext>
		<vm:ChatViewModel/>
	</Design.DataContext>

	<UserControl.Background>
		<ImageBrush Source="avares://VoiceChat.Client/Assets/qwatschi_logo.jpeg" Opacity="0.5"/>
	</UserControl.Background>

	<Grid>

		<Border>
			<Border.Effect>
				<BlurEffect Radius="30"/>
			</Border.Effect>
		</Border>


		<Grid RowDefinitions="60, *,Auto" >
			<Border Margin="-10 0 -10 0" Classes="CurrentChatName" Grid.Row="0" Background="Black">
				<TextBlock Text="Platzhalter Channelname"/>
			</Border>

			<ScrollViewer Grid.Row="1"
						  VerticalScrollBarVisibility="Auto"
						  x:Name="ChatScrollViewer">
				<ItemsControl ItemsSource="{Binding Messages}" VerticalAlignment="Bottom" Classes="Chatbox" >
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border HorizontalAlignment="{Binding HorizontalAlignment}" 
									Background="#5b667199"
									Padding="8 2 8 2"
									ToolTip.Tip="{Binding Timestamp}"
									CornerRadius="12">
								
								<StackPanel>
									<TextBlock IsVisible="{Binding !IsOwnMessage}" Text="{Binding Username}"
											   HorizontalAlignment="{Binding HorizontalAlignment}"
											   FontSize="10"/>
									<TextBlock Classes="ChatMessage"
											   Text="{Binding Text}"
											   FontSize="15"/>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl >
			</ScrollViewer>

			<Border Grid.Row="2"
					Padding="5"
					Margin="0 10 0 0 "
					Background="#2B2B2B"
					BorderBrush="#444"
					BorderThickness="1">
				<Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
					<TextBox Text="{Binding MessageInput}"
							 BorderBrush="Transparent"
							 Watermark="...Message...">
						<TextBox.KeyBindings>
							<KeyBinding Gesture="Enter"
										Command="{Binding SendMessageCommand}" />
						</TextBox.KeyBindings>
					</TextBox>
					<Button Command="{Binding SendMessageCommand}"
							Grid.Column="1"
							Content="⮞"
							Background="Transparent"
							/>
				</Grid>
			</Border>
		</Grid>


	</Grid>


</UserControl>
