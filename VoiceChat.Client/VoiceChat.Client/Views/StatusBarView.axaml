<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VoiceChat.Client.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="30"
             x:DataType="vm:StatusBarViewModel"
             x:Class="VoiceChat.Client.Views.StatusBarView">
  <TextBlock HorizontalAlignment="Left"  VerticalAlignment="Bottom" FontFamily="Default" FontSize="9" Text="{Binding Lastmessage}"/>
</UserControl>
