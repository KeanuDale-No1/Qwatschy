<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VoiceChat.Client.App"
             xmlns:local="clr-namespace:VoiceChat.Client"
             xmlns:cv="using:VoiceChat.Client.Converter"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://VoiceChat.Client/Styles/ThemeResources.axaml"/>
                <ResourceInclude Source="avares://VoiceChat.Client/Styles/Colors.axaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://VoiceChat.Client/Styles/DialogStyles.axaml"/>
        <StyleInclude Source="avares://VoiceChat.Client/Styles/Controls.axaml"/>


        
    </Application.Styles>

</Application>
