<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="VoiceChat.Client.App"
			 xmlns:local="clr-namespace:VoiceChat.Client"
			 xmlns:cv="using:VoiceChat.Client.Converter"
			 RequestedThemeVariant="Default">
	<!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

	<Application.DataTemplates>
		<local:ViewLocator/>
	</Application.DataTemplates>


	<Application.Styles>
		<FluentTheme>
			<FluentTheme.Palettes>
				<ColorPaletteResources x:Key="Light" />
				<ColorPaletteResources x:Key="Dark" />
			</FluentTheme.Palettes>
		</FluentTheme>

		<Style>
			<Style.Resources>
				<ResourceDictionary>
					<ResourceDictionary.ThemeDictionaries>
						<ResourceDictionary x:Key="Light">

							<SolidColorBrush x:Key="ColorBackground">#F4F6FA</SolidColorBrush>
							<SolidColorBrush x:Key="ColorSidebar">#FFFFFF</SolidColorBrush>
							<SolidColorBrush x:Key="ColorChat">#FFFFFF</SolidColorBrush>

							<SolidColorBrush x:Key="ColorBorder">#E5E7EB</SolidColorBrush>
							<SolidColorBrush x:Key="ColorHover">#F1F3F7</SolidColorBrush>

							<SolidColorBrush x:Key="ColorTextPrimary">#111827</SolidColorBrush>
							<SolidColorBrush x:Key="ColorTextSecondary">#6B7280</SolidColorBrush>

							<SolidColorBrush x:Key="ColorAccent">#5865F2</SolidColorBrush>
						</ResourceDictionary>
						<ResourceDictionary x:Key="Dark">
							<SolidColorBrush x:Key="ColorBackground">#1E1F22</SolidColorBrush>
							<SolidColorBrush x:Key="ColorSidebar">#2B2D31</SolidColorBrush>
							<SolidColorBrush x:Key="ColorChat">#313338</SolidColorBrush>

							<SolidColorBrush x:Key="ColorBorder">#3F4147</SolidColorBrush>
							<SolidColorBrush x:Key="ColorHover">#383A40</SolidColorBrush>

							<SolidColorBrush x:Key="ColorTextPrimary">#F2F3F5</SolidColorBrush>
							<SolidColorBrush x:Key="ColorTextSecondary">#B5BAC1</SolidColorBrush>

							<SolidColorBrush x:Key="ColorAccent">#5865F2</SolidColorBrush>
						</ResourceDictionary>
					</ResourceDictionary.ThemeDictionaries>
				</ResourceDictionary>
			</Style.Resources>
		</Style>


		<Style Selector="GridSplitter">
			<Setter Property="Background" Value="{DynamicResource SecondaryColor}" />
			<Setter Property="MinHeight" Value="0"/>
			<Setter Property="MinWidth" Value="0"/>
			<Setter Property="Margin" Value="1"/>
		</Style>

		<Style Selector="Button">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="MinHeight" Value="0"/>
			<Setter Property="MinWidth" Value="0"/>
			<Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
		</Style>

		<Style Selector="Button:pointerover">
			<Setter Property="MinHeight" Value="0"/>
			<Setter Property="MinWidth" Value="0"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Background" Value="{DynamicResource PrimaryColor}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource SecondaryColor}" />
		</Style>


		<Style Selector="TextBox">
			<Setter Property="Background" Value="{DynamicResource TextBoxBackgroundBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource TextBoxBorderBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource TextBoxForegroundBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Padding" Value="8"/>
			<Setter Property="FontSize" Value="14"/>
		</Style>

		<Style Selector="TextBox:focus">
			<Setter Property="BorderBrush" Value="#4C8BF5"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>


		<Style Selector="TextBlock.ChatMessage">
			<Setter Property="Foreground" Value="{DynamicResource TextBoxForegroundBrush}"/>
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Border.ChatMessageBorderBox">
			<Setter Property="BorderBrush" Value="{DynamicResource SecondaryColor}"/>
			<Setter Property="Padding" Value="10"/>
			<Setter Property="Background" Value="{DynamicResource SecondaryColor}"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Margin" Value="5"/>
		</Style>

		<Style Selector="Panel.ChannelPanel">
			<Setter Property="Background" Value="{DynamicResource PrimaryColor}"/>
		</Style>



		<Style Selector="ItemsControl.ChatBox">
			<Setter Property="Padding" Value="10" />
		</Style>



		<Style Selector="Border.CurrentChatName">
			<Setter Property="BorderThickness" Value="0 0 0 1" />
			<Setter Property="BorderBrush" Value="{DynamicResource SecondaryColor}"/>
		</Style>




		<!-- ========================= -->
		<!-- ROOT BACKGROUND -->
		<!-- ========================= -->

		<Style Selector="Grid.appRoot">

			<Setter Property="Background"
					Value="{DynamicResource ColorBackground}"/>

		</Style>

		<!-- ========================= -->
		<!-- SIDEBAR -->
		<!-- ========================= -->

		<Style Selector="Border.sidebar">

			<Setter Property="Background"
					Value="{DynamicResource ColorSidebar}"/>

			<Setter Property="Padding" Value="12"/>

		</Style>


		<Style Selector="Button.channelItem">

			<Setter Property="HorizontalAlignment" Value="Stretch"/>
			<Setter Property="Margin" Value="2"/>
			<Setter Property="Padding" Value="8"/>
			<Setter Property="CornerRadius" Value="8"/>

		</Style>

		<Style Selector="Button.channelItem:pointerover">

			<Setter Property="Background"
					Value="{DynamicResource ColorHover}"/>

		</Style>

		<!-- ========================= -->
		<!-- MEMBER ITEM -->
		<!-- ========================= -->

		<Style Selector="StackPanel.memberItem">

			<Setter Property="Margin" Value="4"/>

		</Style>


		<!-- ========================= -->
		<!-- CHAT HEADER -->
		<!-- ========================= -->

		<Style Selector="TextBlock.chatHeader">

			<Setter Property="FontSize" Value="18"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Margin" Value="12"/>

		</Style>


		<!-- ========================= -->
		<!-- MESSAGE BUBBLE -->
		<!-- ========================= -->

		<Style Selector="Border.messageBubble">

			<Setter Property="Background"
					Value="{DynamicResource ColorHover}"/>

			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="10"/>
			<Setter Property="Margin" Value="4"/>

		</Style>

		<!-- ========================= -->
		<!-- MESSAGE USERNAME -->
		<!-- ========================= -->

		<Style Selector="TextBlock.messageUser">

			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground"
					Value="{DynamicResource ColorTextPrimary}"/>

		</Style>


		<!-- ========================= -->
		<!-- MESSAGE TEXT -->
		<!-- ========================= -->

		<Style Selector="TextBlock.messageText">

			<Setter Property="Foreground"
					Value="{DynamicResource ColorTextPrimary}"/>

		</Style>

		<!-- ========================= -->
		<!-- MESSAGE INPUT -->
		<!-- ========================= -->

		<Style Selector="TextBox.messageInput">

			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="10"/>
			<Setter Property="Margin" Value="8"/>

		</Style>



		<!-- ========================= -->
		<!-- SERVER PANEL -->
		<!-- ========================= -->

		<Style Selector="Border.serverPanel">

			<Setter Property="Background"
					Value="{DynamicResource ColorSidebar}"/>

			<Setter Property="Padding" Value="12"/>

		</Style>

		<!-- ========================= -->
		<!-- SERVER TITLE -->
		<!-- ========================= -->

		<Style Selector="TextBlock.serverTitle">

			<Setter Property="FontSize" Value="20"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Margin" Value="0,10,0,0"/>

		</Style>

		<!-- ========================= -->
		<!-- SERVER DESCRIPTION -->
		<!-- ========================= -->

		<Style Selector="TextBlock.serverDescription">

			<Setter Property="TextWrapping" Value="Wrap"/>
			<Setter Property="Foreground"
					Value="{DynamicResource ColorTextSecondary}"/>

		</Style>


	</Application.Styles>

</Application>