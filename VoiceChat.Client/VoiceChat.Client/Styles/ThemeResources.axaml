<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="BackgroundColor">#E1FFFE</Color>
            <Color x:Key="BackgroundColorField">#ADC4C4</Color>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="PrimaryColor">#71cbfa</Color>
            <Color x:Key="PrimaryHoverColor">#5bb8e8</Color>
            <Color x:Key="TextPrimaryColor">#1F1F1F</Color>
            <Color x:Key="TextSecondaryColor">#5F6368</Color>
            <Color x:Key="BorderColor">#DADCE0</Color>
            <Color x:Key="HoverColor">#E8F0FE</Color>
            <Color x:Key="SelectedColor">#D2E3FC</Color>
            <Color x:Key="DividerColor">#E0E0E0</Color>
            <Color x:Key="InputBackgroundColor">#FFFFFF</Color>
            <Color x:Key="MessageBubbleColor">#F1F3F4</Color>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <Color x:Key="BackgroundColor">#1F1F1F</Color>
            <Color x:Key="BackgroundColorField">#303030</Color>
            <Color x:Key="SurfaceColor">#2D2D2D</Color>
            <Color x:Key="PrimaryColor">#e62f79</Color>
            <Color x:Key="PrimaryHoverColor">#d42a6e</Color>
            <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
            <Color x:Key="TextSecondaryColor">#9AA0A6</Color>
            <Color x:Key="BorderColor">#3F3F3F</Color>
            <Color x:Key="HoverColor">#3D3D3D</Color>
            <Color x:Key="SelectedColor">#4D3D4D</Color>
            <Color x:Key="DividerColor">#3F3F3F</Color>
            <Color x:Key="InputBackgroundColor">#2D2D2D</Color>
            <Color x:Key="MessageBubbleColor">#3D3D3D</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundFieldBrush" Color="{DynamicResource BackgroundColorField}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{DynamicResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{DynamicResource HoverColor}"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="{DynamicResource SelectedColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{DynamicResource DividerColor}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{DynamicResource InputBackgroundColor}"/>
    <SolidColorBrush x:Key="MessageBubbleBrush" Color="{DynamicResource MessageBubbleColor}"/>

    <FontFamily x:Key="DefaultFontFamily">Segoe UI</FontFamily>
    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeHeader">18</x:Double>
    <x:Double x:Key="FontSizeTitle">24</x:Double>

</ResourceDictionary>
